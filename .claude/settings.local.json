{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "45000"
  },
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Skill(update-config)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(*.pem)",
      "Write(package-lock.json)",
      "Write(node_modules/*)"
    ]
  }
}
