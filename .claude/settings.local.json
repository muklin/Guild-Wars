{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm run build)",
      "Bash(git status)",
      "Bash(git diff *)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(*.pem)",
      "Write(package-lock.json)",
      "Write(node_modules/*)"
    ]
  },
  "hooks": {
    "afterWrite": "npm run lint -- --fix {{file}}"
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "45000"
  }
}
