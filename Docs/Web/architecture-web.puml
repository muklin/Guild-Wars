@startuml Guild Wars Web Architecture

!define RECTANGLE(name, desc) rectangle name [ desc ]
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Guild Wars Web Project - C4 Architecture Diagram

Person(user, "Player", "Plays the Guild Wars web game")

System_Boundary(browser, "Web Browser") {
  Container(vite, "Vite Dev Server", "JavaScript", "Builds and serves client code\nHot Module Replacement")

  System_Boundary(client, "Client Application") {
    Component(main, "main.js", "JavaScript", "Application entry point")
    Component(app, "App.js", "JavaScript", "Main game controller\nEvent routing and state management")

    System_Boundary(rendering, "Rendering System") {
      Component(renderer, "WorldRenderer.js", "Three.js", "Scene setup, mesh management\nGeometry rendering and color updates")
      Component(camera, "CameraController.js", "Three.js", "Orthographic camera control\nGaze-lock panning, zoom, rotation")
      Component(colors, "TerrainColors.js", "JavaScript", "Color palette mappings\nTerrain and district color definitions")
    }

    System_Boundary(input, "Input Handling") {
      Component(handler, "InputHandler.js", "JavaScript", "Click and hover detection\nPoint-in-polygon and line-distance algorithms")
      Component(eventbus, "EventBus.js", "JavaScript", "Client-side event pub/sub\nDecouples UI and game logic")
    }

    System_Boundary(ui, "UI System") {
      Component(uimgr, "UIManager.js", "HTML/CSS", "Panel layout and visibility\nError/success dialogs")
      Component(terrain_panel, "TerrainTypePanel.js", "HTML/CSS", "Terrain and edge type selection UI")
      Component(district_panel, "DistrictClassPanel.js", "HTML/CSS", "District class selection UI")
    }

    System_Boundary(api, "API Client") {
      Component(gameapi, "GameAPI.js", "JavaScript", "REST API wrapper\nRequest/response handling")
    }
  }
}

System_Boundary(server, "Node.js Server") {
  Container(express, "Express.js", "JavaScript", "HTTP server and routing\nStatic file serving")

  System_Boundary(engine, "Game Engine") {
    Component(statemanager, "GameStateManager.js", "JavaScript", "Singleton game state\nWorld and city data storage")
    Component(setup_phase, "SetupPhase.js", "JavaScript", "Setup phase state machine\nTerrain, edge, district assignment")
    Component(phase_mgr, "PhaseManager.js", "JavaScript", "Phase transitions\nUpkeep, Planning, Execution, Bills")

    System_Boundary(voronoi, "Voronoi Generation") {
      Component(merged_voronoi, "MergedVoronoiGenerator.js", "JavaScript", "Multi-scale Voronoi with region merging")
      Component(city_voronoi, "CityVoronoiGenerator.js", "JavaScript", "City district grid subdivision")
      Component(delaunay, "DelaunayTriangulator.js", "JavaScript", "Bowyer-Watson triangulation algorithm")
      Component(point, "Point.js", "JavaScript", "2D point data structure")
      Component(triangle, "Triangle.js", "JavaScript", "Triangle with circumcircle calculations")
      Component(edge, "Edge.js", "JavaScript", "Edge representation for Delaunay")
    }

    System_Boundary(domain, "Domain Models") {
      Component(faction, "Faction.js", "JavaScript", "Base faction class (auto ID >= 100)")
      Component(guild, "Guild.js", "JavaScript", "Player/NPC guilds (ID 1-99)")
      Component(district, "District.js", "JavaScript", "City districts (extends Faction)")
      Component(character, "GuildCharacter.js", "JavaScript", "Guild members with attributes")
      Component(threat, "Threat.js", "JavaScript", "Threats to districts")
      Component(tradeable, "Tradeable.js", "JavaScript", "Trade resources")
      Component(destination, "TradingDestination.js", "JavaScript", "Trade route endpoints")
    }
  }
}

System_Boundary(database, "Persistence") {
  Container(gamestate, "Game State", "JSON", "Full game state snapshot\nSerializable for save/load")
}

Rel(user, vite, "Opens browser to", "HTTP localhost:5173")

Rel(vite, main, "Serves", "JavaScript module")

Rel(main, app, "Creates", "Instantiation")

Rel(app, renderer, "Renders world", "Three.js API")
Rel(app, handler, "Initializes input", "Event listeners")
Rel(app, uimgr, "Creates UI", "DOM manipulation")
Rel(app, gameapi, "Calls API", "Fetch HTTP")

Rel(handler, eventbus, "Emits events", "EventBus.emit()")
Rel(terrain_panel, eventbus, "Emits TERRAIN_ASSIGNED", "EventBus")
Rel(district_panel, eventbus, "Emits DISTRICT_CLASS_ASSIGNED", "EventBus")

Rel(eventbus, app, "Delivers events", "EventBus callbacks")
Rel(uimgr, terrain_panel, "Shows during Terrain", "DOM render")
Rel(uimgr, district_panel, "Shows during CitySubdivision", "DOM render")

Rel(gameapi, express, "HTTP requests", "Fetch POST/GET")

Rel(express, statemanager, "Reads/Updates", "Direct access")
Rel(express, setup_phase, "Executes commands", "Method calls")

Rel(setup_phase, merged_voronoi, "Generates regions", "VoronoiWorldGenerator")
Rel(setup_phase, city_voronoi, "Subdivides cities", "CityVoronoiGenerator")

Rel(merged_voronoi, delaunay, "Triangulates", "DelaunayTriangulator")
Rel(delaunay, point, "Uses", "Point objects")
Rel(delaunay, triangle, "Creates", "Triangle objects")
Rel(delaunay, edge, "Finds", "Edge objects")

Rel(setup_phase, statemanager, "Updates", "State assignment")

Rel(statemanager, gamestate, "Serializes", "JSON snapshot")

Rel(gameapi, express, "Receives response", "HTTP JSON")
Rel(renderer, colors, "Looks up colors", "TerrainColors.get()")
Rel(camera, renderer, "Updates camera", "Three.js scene")

note right of vite
  Proxies /api to localhost:3001
  Enables HMR for rapid development
end note

note right of handler
  Region detection: Point-in-polygon (winding number)
  Edge detection: Point-to-line-segment distance (1.5 unit threshold)
  District detection: Point-in-polygon
end note

note right of camera
  Orthographic camera at (25, 60, 25)
  Looking at (25, 0, 25)
  Gaze-lock panning: raycast to y=0 plane, calculate offset
  Zoom: 0.5x to 3.0x via orthographic scale
  Rotation: Q/E snap 90°, orbits around center point
end note

note right of setup_phase
  5 steps:
  1. Generate terrain (15 regions)
  2. Assign terrain types
  3. Assign edge types
  4. Assign district classes
  5. Complete setup
end note

@enduml
