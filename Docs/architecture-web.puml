@startuml Guild Wars Web Architecture
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Guild Wars Web Project - C4 Component Architecture

Person(user, "Player", "Plays the Guild Wars web game")

Container(browser, "Web Browser", "Chrome/Firefox/Safari", "User's browser environment")
Container(nodejs, "Node.js Server", "Express.js", "Game engine and state management")

System_Boundary(client, "Client Application") {
  Component(main, "main.js", "JavaScript", "Entry point, initializes App")
  Component(app, "App.js", "JavaScript", "Game controller, event routing, state management")

  System_Boundary(rendering, "Rendering System") {
    Component(renderer, "WorldRenderer.js", "Three.js", "Scene setup, mesh management, geometry")
    Component(camera, "CameraController.js", "Three.js", "Orthographic camera, gaze-lock panning, zoom, rotation")
    Component(colors, "TerrainColors.js", "JavaScript", "Color palette for terrain and districts")
  }

  System_Boundary(input, "Input System") {
    Component(handler, "InputHandler.js", "JavaScript", "Click/hover detection, point-in-polygon, line-distance")
    Component(eventbus, "EventBus.js", "JavaScript", "Client event pub/sub system")
  }

  System_Boundary(ui, "UI System") {
    Component(uimgr, "UIManager.js", "HTML/CSS", "Panel layout, dialogs, phase UI switching")
    Component(terrain_panel, "TerrainTypePanel.js", "HTML/CSS", "Terrain and edge type selection")
    Component(district_panel, "DistrictClassPanel.js", "HTML/CSS", "District class selection")
  }

  System_Boundary(api, "API Client") {
    Component(gameapi, "GameAPI.js", "JavaScript", "REST API wrapper")
  }
}

System_Boundary(server, "Game Engine") {
  Component(index, "index.js", "Express.js", "HTTP server, REST endpoints, routing")
  Component(statemanager, "GameStateManager.js", "JavaScript", "Singleton game state store")
  Component(setup, "SetupPhase.js", "JavaScript", "Setup state machine, terrain/edge/district assignment")
  Component(phasemgr, "PhaseManager.js", "JavaScript", "Game phase transitions")

  System_Boundary(voronoi, "Voronoi Engine") {
    Component(mergedvoro, "MergedVoronoiGenerator.js", "JavaScript", "Terrain region generation (15 regions)")
    Component(cityvoro, "CityVoronoiGenerator.js", "JavaScript", "City district subdivision (6 districts)")
    Component(delaunay, "DelaunayTriangulator.js", "JavaScript", "Bowyer-Watson triangulation")
    Component(point, "Point.js", "JavaScript", "2D point data structure")
    Component(triangle, "Triangle.js", "JavaScript", "Triangle with circumcircle math")
  }

  System_Boundary(domain, "Domain Models") {
    Component(faction, "Faction.js", "JavaScript", "Base faction (ID >= 100)")
    Component(guild, "Guild.js", "JavaScript", "Guild factions (ID 1-99)")
    Component(district, "District.js", "JavaScript", "City districts")
    Component(character, "GuildCharacter.js", "JavaScript", "Guild members with stats")
  }
}

Container(gamestate, "Game State", "JSON Serializable", "Full game snapshot for persistence")

' Relationships from User
Rel(user, browser, "Opens in browser", "HTTP")

' Browser to Client
Rel(browser, main, "Loads", "JavaScript")
Rel(main, app, "Creates instance", "JavaScript")

' App to subsystems
Rel(app, renderer, "Renders world", "Three.js API")
Rel(app, handler, "Initializes input", "Event listeners")
Rel(app, uimgr, "Creates UI", "HTML/DOM")
Rel(app, gameapi, "Calls API", "Fetch")

' Input system
Rel(handler, eventbus, "Emits events", "EventBus")
Rel(eventbus, app, "Delivers events", "Callbacks")

' UI system
Rel(terrain_panel, eventbus, "Emits TERRAIN_ASSIGNED", "EventBus")
Rel(district_panel, eventbus, "Emits DISTRICT_CLASS_ASSIGNED", "EventBus")
Rel(uimgr, terrain_panel, "Shows during Terrain phase", "DOM manipulation")
Rel(uimgr, district_panel, "Shows during CitySubdivision", "DOM manipulation")

' Rendering system
Rel(renderer, colors, "Looks up colors", "TerrainColors.get()")
Rel(camera, renderer, "Updates camera view", "Three.js scene")

' API communication
Rel(gameapi, index, "HTTP POST/GET", "REST JSON")
Rel(gameapi, browser, "Receives JSON", "HTTP response")

' Server side
Rel(index, statemanager, "Reads/Updates", "Direct access")
Rel(index, setup, "Executes commands", "Method calls")
Rel(index, phasemgr, "Transitions phases", "Method calls")

' Setup phase
Rel(setup, mergedvoro, "Generates regions", "VoronoiWorldGenerator.generate()")
Rel(setup, cityvoro, "Subdivides cities", "CityVoronoiGenerator.generate()")
Rel(setup, statemanager, "Updates state", "GameStateManager.worldTerrainData")

' Voronoi engine
Rel(mergedvoro, delaunay, "Triangulates", "DelaunayTriangulator")
Rel(delaunay, point, "Uses points", "Point objects")
Rel(delaunay, triangle, "Creates triangles", "Triangle objects")

' Domain models
Rel(statemanager, guild, "Manages", "Guild instances")
Rel(statemanager, district, "Manages", "District instances")
Rel(guild, character, "Has members", "GuildCharacter[]*")

' Persistence
Rel(statemanager, gamestate, "Serializes to", "JSON")

' Rendering receives data
Rel(setup, renderer, "Sends terrain data", "setTerrainData(regions, edges)")
Rel(setup, renderer, "Sends city data", "setCityDistrictData(districts)")

' Notes
note on link from app to gameapi
  POST /api/setup/init
  POST /api/setup/terrain/assign
  POST /api/setup/terrain/edge
  POST /api/setup/terrain/done
  POST /api/setup/subdivision/assign
end note

note on link from handler to renderer
  Region: point-in-polygon
  Edge: point-to-line-segment
  District: point-in-polygon
end note

note on link from camera to renderer
  Orthographic at (25,60,25)
  Looking at (25,0,25)
  Gaze-lock: raycast to y=0 plane
  Zoom: 0.5x to 3.0x
  Rotate: Q/E snap 90°
end note

SHOW_LEGEND()

@enduml
