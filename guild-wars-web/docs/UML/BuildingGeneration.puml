@startuml BuildingGeneration
title Building Generation — server city/plot generation through client mesh assembly

skinparam sequenceMessageAlign center
skinparam maxMessageSize 160

actor "SetupPhase\n(server)" as Setup

box "Server — server/engine/CityGenerator" #F0F4FF
  participant "StreetVoronoiGenerator" as Streets
  participant "CityBlockGenerator" as Blocks
  participant "PlotVoronoiGenerator" as Plots
end box

box "Client — rendering" #FFF4EC
  participant "WorldRenderer" as World
  participant "GroundRenderer" as Ground
  participant "BuildingRenderer" as BR
  participant "PartLibrary" as Lib
  participant "ParametricBuilding\n(assemble)" as Asm
  participant "THREE.Scene" as Scene
end box

== Server: city geometry ==

Setup -> Streets : generate(districts, seed)
activate Streets
note right of Streets
  buildJunctions(): per junction, miters each
  consecutive road pair's gutter offsets.
  Beyond MITER_LIMIT, bevels (keeps two
  separate gutter points) instead of spiking.
end note
Streets --> Setup : streetGraph (junctions w/\ngutterLeft/gutterRight)
deactivate Streets

Setup -> Blocks : generate(districts, streetGraph)
activate Blocks
Blocks -> Blocks : _gutterGraphFromJunctions(junctions)
Blocks -> Blocks : _traceFaces(gutterNodes, gutterEdges)
note right
  Most-clockwise-turn traversal of the
  planar gutter graph → one polygon per
  block-shaped face.
end note
Blocks -> Blocks : _simplifyReflexNotches(vertices)
note right
  Strips SHALLOW reflex (concave) vertices
  introduced by junction bevels (sharp-angle
  road pairs) — junction-scale only, so a
  genuine large concave block shape is kept.
end note
Blocks --> Setup : blocks[] (blockCorners, streetEdges)
deactivate Blocks

Setup -> Plots : generate(blocks, districts)
activate Plots
note right of Plots
  Boundary-seeded Voronoi per block,
  clipped to the block polygon and to
  road centrelines.
end note
Plots --> Setup : plots[] (blockCorners, streetEdges,\nblockType, districtId)
deactivate Plots

== Client: dispatch per plot ==

World -> Ground : renderPlots(plots, districtData)
Ground -> BR : render(scene, plots, districtData)
activate BR

loop for each plot
  alt district.assignedType == 'Residential' (parametric)
    alt plot.blockType == 'townhouse'
      BR -> BR : _spawnTownhouse(plot, district)
      note right
        Pass 1 — extrude one wing per street edge, inward
                 by setback + depthBays (depthBays is a
                 minimum-2 bay count, e.g. [2,3,4,5];
                 the extra +setback compensates pass 2's
                 subtraction so depthBays still ends up as
                 the wing's actual net depth).
        Pass 2 — extrude one setback region per street
                 edge, inward by FRONT_SETBACK (per-
                 district override planned: style.front
                 Setback); boolean-subtract it from EVERY
                 wing (a single half-plane clip per edge —
                 two edges' half-planes naturally intersect
                 to carve the right L-shape at a corner).
        Pass 3 — boolean-subtract overlapping wings from
                 each other: largest-area wing wins: every
                 smaller wing it overlaps is replaced by
                 the largest surviving piece of itself
                 minus the bigger wing's polygon.
        Pass 4 — extend a wing's back corner to close a
                 concave-frontage gap with its sibling
                 (tested via each wing's pre-clip back
                 corner; the nearest surviving vertex is
                 nudged to close it).
        Pass 5 — safety-clip every wing to the plot
                 polygon, then drop wings that come out
                 too thin/small (MIN_WING_AREA /
                 MAX_WING_ASPECT).
      end note
      BR -> BR : _buildTownhouseSpec(wings, hash)
      note right
        Per-wing floor list: [{zHeight,height,material}].
        Foundation derived from the ground floor's
        material (raised zHeight, not a separate flag).
        One building-wide jetty roll, capped per wing
        at its own setback.
      end note
    else
      BR -> BR : _spawnParametric(plot, district)
      BR -> BR : _buildSpec(distKey, bw, bd)
      note right: Single-wing degenerate case\n(free-standing house).
    end
    BR -> BR : paraQueue.push({spec, x, z, rotY})
  else
    BR -> BR : _spawn(plot) — fixed GLB house model
  end
  note over BR #FFD
    Per-plot try/catch: one bad spec must not abort
    the rest of the (city-wide) plot loop.
  end note
end

BR -> BR : _suppressPartyWalls(townhouse entries)
note right
  Per block: attaches a snapshot of every sibling
  building's wing polygons + floor lists as
  spec.neighborWings (.slice()'d so a later roof-entry
  push on the original array can't leak into it).
end note

BR -> Lib : _ensureLib().then(...)
activate Lib
Lib --> BR : lib (grid, materials, part geometries)
deactivate Lib

== Client: per-building mesh assembly (async, after PartLibrary loads) ==

loop for each {spec, x, z, rotY} in paraQueue
  BR -> Asm : assemble(spec, lib)
  activate Asm

  loop for each wing in spec.footprint.wings
    Asm -> Asm : build floors/walls\n(per-floor loop over wing.floors)
    note right
      drawIntervals(): Y-range overlap against sibling
      AND neighbour wings — suppresses only the floor
      span an overlapping wing actually reaches.
      Posts/panels/windows/doors placed per bay;
      stone columns + Foundation (battered panels/
      piers) when the ground floor is raised; entrance
      stairs when a door sits above true ground.
    end note
    Asm -> Asm : addBuildingRoof(wing, neighborWings)
    note right
      Ridge always parallel to the street. Footprint
      subtraction removes any OUTRANKING SIBLING's
      overlap first (strictly taller, or tiebreak score
      at equal height) — avoids double-roofing a 3+-way
      wing junction. Each remaining edge: EAVE (sloped,
      overhang unless flush) or GABLE (vertical infill,
      suppressed flush against an outranking neighbour).
    end note
    Asm -> Asm : addWingRoofFeatures(wing)
    note right: Dormers + chimneys, tagged with\na floor level for floor-scroll.
    Asm -> Asm : wing.floors.push({type:'roof', zHeight, height})
  end

  Asm -> Asm : mergeBuilding(wallsGroup)\nmergeBuilding(roofGroup)\nmergeBuilding(interbuildingGroup)
  note right
    Collapses ~50-100 per-part meshes into one
    merged Mesh per material — tags roof
    (userData.isRoof) and party-wall
    (userData.interbuilding) sub-groups so the
    camera/top-down code can toggle them.
  end note
  Asm --> BR : built THREE.Group
  deactivate Asm

  alt assemble() threw
    BR -> BR : console.error(...), skip this building
    note right #FFD: One bad spec must not abort\nthe rest of the async batch.
  else
    BR -> Scene : scene.add(group)
  end
end

deactivate BR

@enduml
