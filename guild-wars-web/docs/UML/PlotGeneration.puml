@startuml PlotGeneration
title Plot Generation — district type assignment through client debug rendering

skinparam sequenceMessageAlign center
skinparam maxMessageSize 160

actor "HTTP Client\n(browser)" as Client
participant "index.js\n(Express routes)" as API

box "Server — server/engine" #F0F4FF
  participant "SetupPhase" as Setup
  participant "CityBlockGenerator" as CBG
  participant "markSquareBlocks()" as MSB
  participant "LandmarkPlacer" as LP
  participant "PlotVoronoiGenerator" as PVG
  participant "markTownhouseBlocks()" as MTB
  participant "extractOuterGutterPolygon()" as EOGP
  participant "convertTerrainCellsToPlots()" as TCTP
end box

box "Client — rendering" #FFF4EC
  participant "App.js" as App
  participant "WorldRenderer" as World
  participant "TerrainRenderer" as TR
  participant "GroundRenderer" as GR
  participant "THREE.Scene" as Scene
end box

== Trigger: user assigns a district type ==

Client -> API : POST /api/district/type\n{ districtId, districtType }
API -> Setup : assignDistrictType(districtId, districtType)
activate Setup

Setup -> Setup : generateForLocked(districtId)
note right of Setup
  Filters cityData.districts to those with
  assignedType set (locked or in preview),
  plus the district being previewed now.
  Delegates to _generateStreetGraph() then
  _generateBuildings().
end note

== _generateBuildings() — city blocks ==

Setup -> CBG : generate(districts, streetGraph)
activate CBG
CBG -> CBG : _gutterGraphFromJunctions(junctions)
note right
  Maps each junction's gutterLeft / gutterRight
  offsets into a planar gutter graph of nodes +
  edges (one node per gutter corner, edges
  along each road's two gutter lines).
end note
CBG -> CBG : _traceFaces(gutterNodes, gutterEdges)
note right
  Most-clockwise-turn traversal of the planar
  gutter graph. Each enclosed face = one block
  polygon (blockCorners).
end note
CBG -> CBG : _simplifyReflexNotches(vertices)
note right
  Strips shallow reflex vertices introduced by
  junction bevels — junction-scale only, so a
  genuine concave block shape is preserved.
end note
CBG --> Setup : blocks[] { id, districtId, blockCorners,\n  streetEdges, area }
deactivate CBG

== _generateBuildings() — square + landmark pre-passes ==

Setup -> MSB : markSquareBlocks(blocks, districts)
note right of MSB
  Tags block.blockType = 'square' for any block
  whose area < district.params.square_threshold.
  Must run before Landmark placement so squares
  are known when landmark clusters are seeded.
end note

Setup -> LP : place(blocks, districts, junctions,\n  streetGraph, seed)
activate LP
LP --> Setup : landmarkFootprints[] (polygons to\n  exclude from city plots)
deactivate LP

== _generateBuildings() — city plot Voronoi ==

Setup -> PVG : generate(blocks, districts, junctions,\n  roadEdges, landmarkFootprints)
activate PVG

loop for each block
  alt block.blockType == 'square'
    PVG -> PVG : emit one plot = entire blockCorners\n(blockType: 'square')
    note right: Squares are their own single plot;\nno Voronoi subdivision needed.
  else normal block
    PVG -> PVG : seedsFromBoundary(blockCorners)
    note right
      Seeds placed inward along each block edge
      at intervals proportional to block size.
      Keeps Voronoi cells roughly street-facing.
    end note
    PVG -> PVG : voronoiCells(seeds, blockCorners)
    loop for each Voronoi cell
      PVG -> PVG : intersectPolygons(cell.polygon,\n  blockCorners)
      note right
        Clips Voronoi cell to the block polygon.
        Result is the final plot shape.
      end note
      alt overlaps a landmark footprint
        PVG -> PVG : drop plot (landmark occupies this cell)
      else
        PVG -> PVG : plots.push({ id, blockId, districtId,\n  blockCorners: clipped, streetEdges })
      end
    end
  end
end

PVG --> Setup : plots[] { id, blockId, districtId,\n  blockCorners, streetEdges, blockType }
deactivate PVG

Setup -> MTB : markTownhouseBlocks(blocks, plots, districts)
note right of MTB
  Tags block.blockType = 'townhouse' when
  townhouse probability roll succeeds for the
  block's district. Probability is per-district in
  districtConfig.js (every district type can roll).
  BuildingRenderer reads blockType from the PLOT,
  not the block, so plots are also tagged here.
end note

note over Setup : cityData.plots = plots

== _generateBuildings() — terrain plot conversion ==

Setup -> EOGP : extractOuterGutterPolygon(blocks)
activate EOGP
note right of EOGP
  Collects every block edge that appears in one
  block only (no reverse twin) — these are the
  outer boundary edges of the city block mesh.
  Chains them into a closed polygon: the city's
  outer gutter ring.
end note
EOGP --> Setup : outerGutterPoly [{x,y}] (or null)
deactivate EOGP

Setup -> Setup : filter worldTerrainData.fineCells\nto non-City parentRegionId
note right
  City-region fine cells become city content
  (streets, plots, buildings). Only cells whose
  parent region is NOT the City region are
  converted to terrain plots.
end note

Setup -> TCTP : convertTerrainCellsToPlots(\n  terrainFineCells, outerGutterPoly,\n  tradeRoadWaypoints, worldRegions)
activate TCTP
note right of TCTP
  outerGutterPoly is accepted for backward compat
  but NOT used for clipping. The city gutter is
  non-convex (star-shaped), so per-edge S-H
  half-plane clipping incorrectly removes terrain
  near concave corners. City plots at GROUND_Y
  cover any boundary overlap; terrain plots sit
  at GROUND_Y − 0.001 underneath.
end note

TCTP -> TCTP : regionTypeById = Map(worldRegions,\n  r => [r.id, r.assignedType])
note right
  Fine cells always have assignedType: null —
  the type lives on the coarse parent region.
  Build a lookup map once, apply per cell.
end note

loop for each terrainFineCell
  TCTP -> TCTP : poly = cell.polygon (no clip)
  TCTP -> TCTP : assignedType = regionTypeById\n  .get(cell.parentRegionId)
  TCTP -> TCTP : hasRoad = roadSegments.some(\n  seg => polygonCrossesSegment(poly, seg))
  TCTP -> TCTP : plots.push({ id:'t{n}', type:'terrain',\n  assignedType, blockCorners: poly, hasRoad })
end

TCTP --> Setup : terrainPlots[] { id, type:'terrain',\n  assignedType, blockCorners, hasRoad }
deactivate TCTP

note over Setup : cityData.terrainPlots = terrainPlots

Setup --> API : cityData (plots, terrainPlots,\n  blocks, streetGraph, …)
deactivate Setup

API --> Client : 200 OK + broadcast()

== Client: _renderCityGeometry(cityData) ==

App -> World : renderPlots(cityData.plots, cityData)
World -> GR : renderPlots(plots, districtData)
activate GR

loop for each city plot
  GR -> GR : _makeFill(blockCorners, districtColor,\n  GROUND_Y)
  note right
    THREE.ShapeUtils.triangulateShape() on the
    plot polygon. Emits MeshStandardMaterial with
    district colour + slight emissive.
    Side: DoubleSide so winding does not matter.
  end note
  GR -> Scene : scene.add(mesh)
end

deactivate GR

App -> World : renderTerrainPlots(cityData.terrainPlots)
activate World
World -> TR : deleteNonCityFineCells()
note right of TR
  Removes TerrainRenderer's original fine-cell
  meshes for every non-City region so terrain
  plots (with correct gutter-aligned boundaries)
  take over without double-rendering.
end note
World -> GR : renderTerrainPlots(terrainPlots)
activate GR

loop for each terrain plot
  GR -> GR : color = TERRAIN_FILL_COLORS[assignedType]\n  ?? TERRAIN_FILL_COLORS.unassigned
  GR -> GR : _makeFill(blockCorners, color,\n  GROUND_Y − 0.001)
  note right
    1 mm below city content so city plot fills
    naturally cover any boundary overlap at
    the gutter — no explicit gutter clip needed.
  end note
  GR -> Scene : scene.add(mesh)
  note right: If showDebug is already on, replaces\nmaterial with random HSL colour immediately.
end

deactivate GR
deactivate World

App -> World : drawPlotCenters(\n  [...cityData.plots, ...cityData.terrainPlots])
World -> GR : drawPlotCenters(allPlots)
activate GR

loop for each plot (city + terrain)
  GR -> GR : cx,cy = centroid(blockCorners)
  GR -> GR : SphereGeometry(r=0.022)
  note right
    Green spheres (0x00ff88) for both city and
    terrain plots — added to _plotDebugMeshes,
    controlled by the "Plot Centre points" debug
    layer checkbox. Visible only when showDebug.
  end note
  GR -> Scene : scene.add(sphere)\n[visible: showDebug && _plotCentersVisible]
end

deactivate GR

== On save-load: terrain plot migration ==

note over API
  On server startup, after deserializing the
  autosave, terrain plots are always regenerated
  from the current world fine cells. This fixes
  plots from older saves (S-H clipping gaps,
  null assignedType). The resaved autosave then
  has clean terrain plots for future loads.
end note

API -> Setup : regenerateTerrainPlots()
activate Setup
Setup -> EOGP : extractOuterGutterPolygon(cityData.blocks)
EOGP --> Setup : outerGutterPoly
Setup -> TCTP : convertTerrainCellsToPlots(\n  terrainFineCells, outerGutterPoly,\n  tradeRoadWaypoints, worldRegions)
TCTP --> Setup : terrainPlots[]
note right : cityData.terrainPlots = terrainPlots
deactivate Setup
API -> API : autoSave()

@enduml
